// Auth.js models + onboarding fields (PostgreSQL). See https://authjs.dev/getting-started/adapters/prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationSize {
  SOLO
  FROM_2_TO_10
  FROM_11_TO_50
  FROM_51_TO_200
  OVER_200
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  firstName             String?
  lastName              String?
  phone                 String?
  businessName          String?
  logoUrl               String?
  hearAboutUs           String?
  organizationSize      OrganizationSize?
  themeId               String?
  onboardingStep        Int               @default(0)
  onboardingCompletedAt DateTime?

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
